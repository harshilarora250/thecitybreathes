# The City Breathes — environment variables
# Copy to .env (local) or set these in the Vercel dashboard. Never commit .env.

# Cloudflare Turnstile secret key (console human-check).
# Public site key is in src/app.js; this secret stays server-side only.
TURNSTILE_SECRET_KEY=

# TomTom Traffic API key — powers real "higher traffic -> faster breathing".
# Free tier: 2,500 requests/day, global coverage. Get one at:
#   https://developer.tomtom.com/  (create app -> copy the API key)
# Used only server-side by /api/traffic; the browser never sees it.
# If unset, the app falls back to a time-of-day traffic estimate.
TOMTOM_TRAFFIC_KEY=
